# Google Tag Manager (for Google Ads conversion tracking)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps / Places
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Square Payments
NEXT_PUBLIC_SQUARE_APP_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox
SQUARE_ACCESS_TOKEN=

# SMTP config for contact form emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Security: Admin emails (comma-separated list of emails allowed as admin)
ADMIN_EMAILS=

# Security: Square webhook signature verification key
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Security: Webhook URL (the full URL Square sends webhooks to)
SQUARE_WEBHOOK_URL=

# Security: HMAC secret for reservation access tokens (REQUIRED — no fallback)
HMAC_SECRET=
